# grader-v2 환경변수 예시 (.env 로 복사해서 값 채워 쓰세요 — .env 는 git 에 안 올라감)
#
# ⚠️ 로컬(직원 PC)에서는 이 파일이 없어도 됩니다.
#    아무 env 도 안 켜면 기존처럼 '무인증·로컬 GS 경로·포트 8000' 으로 그대로 돕니다(회귀 0).
#    아래 값들은 '배포(인터넷 공개)' 할 때만 필요합니다.

# ── 인증 토글 ──────────────────────────────────────────────
# 1/true 면 로그인 필수(배포). 비워두거나 0 이면 무인증(로컬 기본).
GRADER_REQUIRE_AUTH=

# ── Ghostscript 경로 ───────────────────────────────────────
# 도커/리눅스면 gs (PATH). 비워두면 로컬 Windows 절대경로 자동탐색 폴백.
GS_BIN=

# ── 서버 포트 ──────────────────────────────────────────────
# 배포 플랫폼이 주입(Render 등). 비워두면 8000.
PORT=

# ── Supabase (배포 인증용) ─────────────────────────────────
# 공개키(프런트 노출 OK) — introspection apikey·프런트 createClient 에 사용:
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# 비밀키(절대 프런트·레포 노출 금지 — 서버 환경변수로만, 현재 검증엔 미사용·향후 admin API 대비):
SUPABASE_SECRET_KEY=

# ── Google Drive (패턴 라이브러리 연동) ────────────────────
# 서버가 '서비스 계정(로봇 계정)' 으로 공유드라이브를 읽기 전용 탐색·다운로드한다.
# 안 채우면 이 기능만 비활성(기존 동작엔 영향 0). 배포 시에만 필요.
# 서비스계정 JSON — 원본 JSON 문자열 또는 base64 한 줄(줄바꿈 많아 base64 권장):
#   base64 만들기(예): base64 -w0 service-account.json   또는   PowerShell 인코딩
GDRIVE_SA_JSON=
# 트리 탐색 시작(루트) 폴더 ID — Drive 에서 폴더 열고 URL .../folders/<여기> 복사:
GDRIVE_ROOT_FOLDER_ID=
