# grader-v2 환경변수 예시 (.env 로 복사해서 값 채워 쓰세요 — .env 는 git 에 안 올라감)
#
# ⚠️ 로컬(직원 PC)에서는 이 파일이 없어도 됩니다.
#    아무 env 도 안 켜면 기존처럼 '무인증·로컬 GS 경로·포트 8000' 으로 그대로 돕니다(회귀 0).
#    아래 값들은 '배포(인터넷 공개)' 할 때만 필요합니다.

# ── 인증 토글 ──────────────────────────────────────────────
# 1/true 면 로그인 필수(배포). 비워두거나 0 이면 무인증(로컬 기본).
GRADER_REQUIRE_AUTH=

# ── Ghostscript 경로 ───────────────────────────────────────
# 도커/리눅스면 gs (PATH). 비워두면 로컬 Windows 절대경로 자동탐색 폴백.
GS_BIN=

# ── 서버 포트 ──────────────────────────────────────────────
# 배포 플랫폼이 주입(Render 등). 비워두면 8000.
PORT=

# ── Supabase (배포 인증용) ─────────────────────────────────
# 공개키(프런트 노출 OK):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 비밀키(절대 프런트·레포 노출 금지 — 서버 환경변수로만):
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
