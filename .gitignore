# Python 캐시 (자동 생성, 백업 불필요)
__pycache__/
*.pyc
*.pyo

# 엔진 실행 시 생성되는 임시 출력물 (재생성 가능)
_selftest_out/
_build_out/

# 시험 렌더 생성물 (compare_mapping.py 재실행으로 재생성 가능, 무거움)
grading_compare/*.pdf
grading_compare/previewA/
grading_compare/previewB/
grading_compare/_measure/

# grade 합성 결과물 (python -m engine grade 재실행으로 재생성)
# _grade_out, _grade_out_text2, _grade_out_reg 등 모든 grade 출력 폴더 포함
_grade_out*/

# job 작업 산출물 (선수별 PDF/PNG, 무거움 — job 재실행으로 재생성)
data/jobs/

# 웹앱 업로드 임시저장소 (브라우저가 올린 주문서·디자인을 엔진에 넘기려 잠시 보관)
data/uploads/

# 웹앱 설정 (직원 PC별 GS 경로·출력형식 등 — 환경마다 달라 추적 대상 아님)
data/settings.json

# 디자인 원본 .ai (1.7~1.9MB 바이너리, preset design_file/글리프셋 소스가 참조)
# clone 시 디자이너에게 별도 확보 필요. design_source/README.md 참고.
design_source/*.ai

# 가상환경
.venv/
venv/
env/

# OS/에디터 부산물
Thumbs.db
.DS_Store
*.swp

# 글리프셋/합성 임시 검증 산출물 (job 재실행으로 재생성)
_glyphtest/
